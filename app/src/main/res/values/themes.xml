<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme — used for the launch window before Compose takes over -->
    <style name="Theme.NadjahAcademy" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Splash / launch window background -->
        <item name="android:windowBackground">@color/splash_background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <!-- Edge-to-edge -->
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>

    <!-- Splash screen theme (Android 12+ SplashScreen API) -->
    <style name="Theme.NadjahAcademy.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_logo</item>
        <item name="windowSplashScreenIconBackgroundColor">@color/splash_background</item>
        <item name="postSplashScreenTheme">@style/Theme.NadjahAcademy</item>
    </style>

</resources>
